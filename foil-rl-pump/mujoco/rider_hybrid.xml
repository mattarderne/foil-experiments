<!--
  Pump Foil Rider - Hybrid Mode (Surf Stance)

  Board position is controlled externally (via qpos).
  Body joints are simulated by MuJoCo.
  Rider CoM is tracked to compute reaction forces.

  Surf stance: front foot forward (+X), back foot back (-X)
  Rider faces sideways (perpendicular to direction of travel)
-->
<mujoco model="pump_foil_rider_hybrid">
  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.01" gravity="0 0 -9.81" integrator="implicitfast"/>

  <default>
    <!-- No collisions - we're flying -->
    <geom contype="0" conaffinity="0"/>
    <!-- Moderate joint damping -->
    <joint damping="10" armature="0.1"/>
    <!-- Position actuators -->
    <position kp="500" kv="50"/>
  </default>

  <asset>
    <material name="board" rgba="0.6 0.3 0.1 1"/>
    <material name="skin" rgba="1.0 0.85 0.7 1"/>
    <material name="torso_mat" rgba="0.2 0.4 0.6 1"/>
    <material name="leg" rgba="0.3 0.3 0.5 1"/>
    <material name="water" rgba="0.2 0.5 0.8 0.3"/>
  </asset>

  <worldbody>
    <camera name="side" pos="0 5 1" xyaxes="-1 0 0 0 0 1" mode="trackcom"/>
    <camera name="front" pos="5 0 1" xyaxes="0 1 0 0 0 1" mode="trackcom"/>
    <camera name="quarter" pos="4 4 1.5" xyaxes="-1 1 0 0 0 1" mode="trackcom"/>

    <!-- Water surface (visual) -->
    <geom name="water" type="plane" pos="0 0 0" size="20 20 0.01" material="water"/>

    <!-- BOARD - has freejoint but we control it via qpos -->
    <!-- Board is longer in X (direction of travel), narrower in Y -->
    <body name="board" pos="0 0 0.2">
      <freejoint name="root"/>
      <geom name="board_geom" type="box" size="0.7 0.20 0.025" mass="6" material="board"/>

      <!-- RIDER - surf stance, facing sideways (+Y direction) -->
      <!-- Pelvis centered between feet -->
      <body name="pelvis" pos="0 0 0.90">
        <geom name="pelvis_geom" type="box" size="0.12 0.10 0.08" mass="12" material="leg"/>

        <!-- FRONT LEG (left) - forward on board -->
        <body name="left_thigh" pos="0.20 0 -0.04">
          <joint name="left_hip" type="hinge" axis="0 1 0" range="-0.5 1.2" damping="15"/>
          <geom name="left_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.42" size="0.055" mass="8" material="leg"/>

          <body name="left_shin" pos="0 0 -0.42">
            <joint name="left_knee" type="hinge" axis="0 1 0" range="-2.4 -0.1" damping="10"/>
            <geom name="left_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.40" size="0.045" mass="4" material="leg"/>
            <geom name="left_foot" type="box" size="0.12 0.05 0.02" pos="0 0 -0.42" mass="1" material="leg"/>
          </body>
        </body>

        <!-- BACK LEG (right) - back on board -->
        <body name="right_thigh" pos="-0.20 0 -0.04">
          <joint name="right_hip" type="hinge" axis="0 1 0" range="-0.5 1.2" damping="15"/>
          <geom name="right_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.42" size="0.055" mass="8" material="leg"/>

          <body name="right_shin" pos="0 0 -0.42">
            <joint name="right_knee" type="hinge" axis="0 1 0" range="-2.4 -0.1" damping="10"/>
            <geom name="right_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.40" size="0.045" mass="4" material="leg"/>
            <geom name="right_foot" type="box" size="0.12 0.05 0.02" pos="0 0 -0.42" mass="1" material="leg"/>
          </body>
        </body>

        <!-- TORSO - faces sideways -->
        <body name="torso" pos="0 0 0.04">
          <joint name="waist" type="hinge" axis="0 1 0" range="-0.4 0.4" damping="12"/>
          <geom name="torso_geom" type="capsule" fromto="0 0 0 0 0 0.45" size="0.11" mass="28" material="torso_mat"/>

          <!-- HEAD -->
          <body name="head" pos="0 0 0.55">
            <geom name="head_geom" type="sphere" size="0.09" mass="5" material="skin"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Actuators for legs and waist -->
  <actuator>
    <position name="left_hip_act" joint="left_hip" kp="600" ctrlrange="-0.5 1.2"/>
    <position name="right_hip_act" joint="right_hip" kp="600" ctrlrange="-0.5 1.2"/>
    <position name="left_knee_act" joint="left_knee" kp="400" ctrlrange="-2.4 -0.1"/>
    <position name="right_knee_act" joint="right_knee" kp="400" ctrlrange="-2.4 -0.1"/>
    <position name="waist_act" joint="waist" kp="500" ctrlrange="-0.4 0.4"/>
  </actuator>

  <!-- Sensors -->
  <sensor>
    <!-- Board state -->
    <framepos name="board_pos" objtype="body" objname="board"/>
    <framequat name="board_quat" objtype="body" objname="board"/>
    <framelinvel name="board_vel" objtype="body" objname="board"/>
    <frameangvel name="board_angvel" objtype="body" objname="board"/>

    <!-- Rider center of mass (key for computing reaction forces) -->
    <subtreecom name="rider_com" body="pelvis"/>
    <subtreelinvel name="rider_vel" body="pelvis"/>

    <!-- Joint positions -->
    <jointpos name="left_hip_pos" joint="left_hip"/>
    <jointpos name="right_hip_pos" joint="right_hip"/>
    <jointpos name="left_knee_pos" joint="left_knee"/>
    <jointpos name="right_knee_pos" joint="right_knee"/>
    <jointpos name="waist_pos" joint="waist"/>

    <!-- Joint velocities -->
    <jointvel name="left_hip_vel" joint="left_hip"/>
    <jointvel name="right_hip_vel" joint="right_hip"/>
    <jointvel name="left_knee_vel" joint="left_knee"/>
    <jointvel name="right_knee_vel" joint="right_knee"/>
    <jointvel name="waist_vel" joint="waist"/>
  </sensor>
</mujoco>
