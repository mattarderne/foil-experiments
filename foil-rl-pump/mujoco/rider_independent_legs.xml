<!--
  Pump Foil Rider - Independent Front/Back Leg Control

  Unlike rider_final.xml which couples legs via tendons, this model
  allows independent front/back leg movement for weight shift control.

  This is CRITICAL for learning pump technique:
  - Extend front + compress back = shift weight forward = nose down
  - Compress front + extend back = shift weight back = nose up

  The pitch control through weight shift is how riders generate propulsion.
-->
<mujoco model="rider_independent_legs">
  <compiler angle="radian"/>
  <option timestep="0.01" gravity="0 0 -9.81"/>

  <visual>
    <global offwidth="640" offheight="480"/>
    <rgba haze="0.3 0.5 0.7 1"/>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2"/>
  </visual>

  <default>
    <geom contype="0" conaffinity="0"/>
    <joint damping="20"/>
  </default>

  <asset>
    <material name="board" rgba="0.8 0.5 0.2 1"/>
    <material name="foot" rgba="0.6 0.5 0.4 1"/>
    <material name="shin" rgba="0.4 0.5 0.8 1"/>
    <material name="thigh" rgba="0.7 0.4 0.7 1"/>
    <material name="pelvis" rgba="0.9 0.7 0.5 1"/>
    <material name="torso" rgba="1.0 0.4 0.4 1"/>
    <material name="arm" rgba="0.95 0.8 0.7 1"/>
    <material name="head" rgba="1.0 0.85 0.75 1"/>
    <material name="water" rgba="0.4 0.7 1.0 0.1"/>
    <material name="sky" rgba="0.7 0.85 1.0 1"/>
    <material name="mast" rgba="0.2 0.2 0.2 1"/>
    <material name="foil" rgba="0.3 0.3 0.3 1"/>
  </asset>

  <worldbody>
    <camera name="side" pos="0 4 1.2" xyaxes="-1 0 0 0 0 1"/>
    <camera name="front" pos="4 0 1.2" xyaxes="0 1 0 0 0 1"/>
    <camera name="quarter" pos="3 3 2.0" xyaxes="-0.7 0.7 0 0 0 1"/>
    <camera name="top" pos="0 0 4" xyaxes="1 0 0 0 1 0"/>

    <!-- Water surface -->
    <geom name="water" type="plane" pos="0 0 -0.30" size="50 50 0.1" material="water"/>
    <!-- Horizon/sky backdrop -->
    <geom name="sky" type="plane" pos="0 -20 0" size="50 50 0.1" euler="1.57 0 0" material="sky"/>

    <!-- BOARD -->
    <body name="board" pos="0 0 0.5">
      <freejoint name="root"/>
      <geom name="board_geom" type="box" size="0.6 0.18 0.02" mass="6" material="board"/>

      <!-- FOIL ASSEMBLY (visual only) -->
      <geom name="mast" type="capsule" fromto="0 0 -0.02 0 0 -0.75" size="0.02" mass="0.1" material="mast"/>
      <geom name="front_wing" type="box" pos="0.05 0 -0.75" size="0.15 0.22 0.015" mass="0.1" material="foil"/>
      <geom name="fuselage" type="capsule" fromto="0.05 0 -0.75 -0.35 0 -0.75" size="0.015" mass="0.1" material="mast"/>
      <geom name="stabilizer" type="box" pos="-0.35 0 -0.75" size="0.08 0.12 0.01" mass="0.1" material="foil"/>

      <!-- Tracking cameras -->
      <camera name="track_side" pos="0 5 0.5" xyaxes="-1 0 0 0 0 1" mode="trackcom"/>
      <camera name="track_quarter" pos="2 4 1.0" xyaxes="-0.6 0.8 0 0 0 1" mode="trackcom"/>

      <!-- ===== FRONT LEG (at +X, nose of board) ===== -->
      <body name="front_foot" pos="0.25 0 0.04">
        <geom name="front_foot_geom" type="box" size="0.10 0.05 0.02" mass="1" material="foot"/>

        <body name="front_shin" pos="0 0 0.02">
          <joint name="front_ankle" type="hinge" axis="0 1 0" range="-0.4 0.4"/>
          <geom name="front_shin_geom" type="capsule" fromto="0 0 0 -0.08 0 0.34" size="0.04" mass="4" material="shin"/>
          <geom name="front_knee_geom" type="sphere" pos="-0.08 0 0.34" size="0.06" mass="0.5" material="thigh"/>

          <body name="front_thigh" pos="-0.08 0 0.34">
            <joint name="front_knee" type="hinge" axis="0 1 0" range="-1.5 0.2"/>
            <geom name="front_thigh_geom" type="capsule" fromto="0 0 0 -0.10 0 0.40" size="0.05" mass="6" material="thigh"/>

            <!-- Pelvis (upper body attaches here) -->
            <body name="pelvis" pos="-0.10 0 0.40">
              <joint name="front_hip" type="hinge" axis="0 1 0" range="-1.0 1.5"/>
              <geom name="pelvis_geom" type="ellipsoid" size="0.14 0.18 0.10" mass="15" material="pelvis"/>

              <site name="pelvis_back_attach" pos="-0.15 0 0" size="0.02"/>

              <!-- TORSO -->
              <body name="torso" pos="0 0 0.10">
                <joint name="waist" type="hinge" axis="0 1 0" range="-0.5 0.5"/>
                <geom name="torso_geom" type="capsule" fromto="0 0 0 0 0 0.45" size="0.10" mass="25" material="torso"/>

                <!-- HEAD -->
                <body name="head" pos="0 0 0.52">
                  <geom name="head_geom" type="sphere" size="0.10" mass="5" material="head"/>
                </body>

                <!-- LEFT ARM -->
                <body name="left_arm" pos="0 0.12 0.40">
                  <joint name="left_shoulder" type="hinge" axis="0 1 0" range="-2.0 2.0"/>
                  <geom name="left_arm_geom" type="capsule" fromto="0 0 0 0 0 -0.55" size="0.03" mass="4" material="arm"/>
                </body>

                <!-- RIGHT ARM -->
                <body name="right_arm" pos="0 -0.12 0.40">
                  <joint name="right_shoulder" type="hinge" axis="0 1 0" range="-2.0 2.0"/>
                  <geom name="right_arm_geom" type="capsule" fromto="0 0 0 0 0 -0.55" size="0.03" mass="4" material="arm"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

      <!-- ===== BACK LEG (at -X, tail of board) ===== -->
      <body name="back_foot" pos="-0.25 0 0.04">
        <geom name="back_foot_geom" type="box" size="0.10 0.05 0.02" mass="1" material="foot"/>

        <body name="back_shin" pos="0 0 0.02">
          <joint name="back_ankle" type="hinge" axis="0 1 0" range="-0.4 0.4"/>
          <geom name="back_shin_geom" type="capsule" fromto="0 0 0 0.08 0 0.34" size="0.04" mass="4" material="shin"/>
          <geom name="back_knee_geom" type="sphere" pos="0.08 0 0.34" size="0.06" mass="0.5" material="thigh"/>

          <body name="back_thigh" pos="0.08 0 0.34">
            <joint name="back_knee" type="hinge" axis="0 1 0" range="-1.5 0.2"/>
            <geom name="back_thigh_geom" type="capsule" fromto="0 0 0 0.10 0 0.40" size="0.05" mass="6" material="thigh"/>

            <!-- Back hip connection point -->
            <body name="back_hip_point" pos="0.10 0 0.40">
              <joint name="back_hip" type="hinge" axis="0 1 0" range="-1.0 1.5"/>
              <geom name="back_hip_geom" type="sphere" size="0.05" mass="1" rgba="0.7 0.5 0.3 0"/>
              <site name="back_hip_attach" pos="0 0 0" size="0.02"/>
            </body>
          </body>
        </body>
      </body>

    </body>
  </worldbody>

  <!-- Constrain back leg to follow pelvis (closed kinematic chain) -->
  <equality>
    <connect body1="back_hip_point" body2="pelvis" anchor="0 0 0"/>
  </equality>

  <!-- NO TENDONS - legs move independently! -->

  <!-- Actuators for ALL leg joints (front AND back) -->
  <actuator>
    <!-- Front leg -->
    <position name="front_ankle_act" joint="front_ankle" kp="200" ctrlrange="-0.4 0.4"/>
    <position name="front_knee_act" joint="front_knee" kp="300" ctrlrange="-1.5 0.2"/>
    <position name="front_hip_act" joint="front_hip" kp="400" ctrlrange="-1.0 1.5"/>

    <!-- Back leg (INDEPENDENT control) -->
    <position name="back_ankle_act" joint="back_ankle" kp="200" ctrlrange="-0.4 0.4"/>
    <position name="back_knee_act" joint="back_knee" kp="300" ctrlrange="-1.5 0.2"/>
    <position name="back_hip_act" joint="back_hip" kp="400" ctrlrange="-1.0 1.5"/>

    <!-- Upper body -->
    <position name="waist_act" joint="waist" kp="300" ctrlrange="-0.5 0.5"/>
    <position name="left_shoulder_act" joint="left_shoulder" kp="100" ctrlrange="-2.0 2.0"/>
    <position name="right_shoulder_act" joint="right_shoulder" kp="100" ctrlrange="-2.0 2.0"/>
  </actuator>
</mujoco>
