<!--
  Pump Foil Rider - MuJoCo MJCF Model

  Matches the custom body model from body_model.py:
  - Shin: 0.45m, 5kg (per leg)
  - Thigh: 0.45m, 10kg (per leg)
  - Torso: 0.50m, 35kg
  - Upper arm: 0.30m, 3kg (per arm)
  - Forearm: 0.25m, 2kg (per arm)
  - Total: ~70kg rider + 6kg board

  Coordinate system:
  - X: forward (direction of travel)
  - Y: lateral (stance width)
  - Z: up (vertical)

  Kinematic chain (from feet up):
  - Board (floating base, receives foil forces)
  - Shins (fixed to board at ankles)
  - Thighs (knee joint)
  - Pelvis (hip joints connect thighs)
  - Torso (waist joint)
  - Arms (shoulder/elbow joints)
  - Head
-->

<mujoco model="pump_foil_rider">
  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.01" gravity="0 0 -9.81"/>

  <visual>
    <global offwidth="1920" offheight="1080"/>
    <quality shadowsize="2048"/>
  </visual>

  <default>
    <joint damping="50" armature="0.5"/>  <!-- Higher damping for stability -->
    <geom contype="1" conaffinity="1" friction="1 0.5 0.5"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <asset>
    <material name="board" rgba="0.6 0.3 0.1 1"/>
    <material name="skin" rgba="1.0 0.85 0.7 1"/>
    <material name="torso_mat" rgba="0.2 0.4 0.6 1"/>
    <material name="leg" rgba="0.3 0.3 0.5 1"/>
    <material name="arm" rgba="0.3 0.5 0.3 1"/>
    <material name="water" rgba="0.2 0.5 0.8 0.3"/>
  </asset>

  <worldbody>
    <!-- Cameras -->
    <camera name="side" pos="0 5 1" xyaxes="-1 0 0 0 0 1" mode="trackcom"
            target="board"/>
    <camera name="front" pos="5 0 1" xyaxes="0 1 0 0 0 1" mode="trackcom"
            target="board"/>
    <camera name="iso" pos="3 3 2" xyaxes="-0.7 0.7 0 0 0 1" mode="trackcom"
            target="board"/>

    <!-- Water surface (visual only) -->
    <geom name="water_surface" type="plane" pos="0 0 0" size="10 10 0.01"
          material="water" contype="0" conaffinity="0"/>

    <!-- Board with 6DoF freejoint -->
    <body name="board" pos="0 0 0.2">
      <freejoint name="board_joint"/>
      <geom name="board_geom" type="box" size="0.7 0.25 0.025" mass="6"
            material="board" pos="0 0 0"/>
      <site name="mast_base" pos="0 0 -0.025" size="0.02"/>

      <!-- LEFT LEG: shin -> thigh -->
      <body name="left_shin" pos="-0.05 0.15 0.05">
        <!-- Shin: 0.45m, 5kg -->
        <geom name="left_shin_geom" type="capsule" fromto="0 0 0  0 0 0.45"
              size="0.04" mass="5" material="leg"/>

        <!-- Thigh with knee joint -->
        <body name="left_thigh" pos="0 0 0.45">
          <joint name="left_knee" type="hinge" axis="0 1 0" range="0 2.5"/>
          <geom name="left_thigh_geom" type="capsule" fromto="0 0 0  0 0 0.45"
                size="0.05" mass="10" material="leg"/>
        </body>
      </body>

      <!-- RIGHT LEG: shin -> thigh -->
      <body name="right_shin" pos="-0.05 -0.15 0.05">
        <geom name="right_shin_geom" type="capsule" fromto="0 0 0  0 0 0.45"
              size="0.04" mass="5" material="leg"/>

        <body name="right_thigh" pos="0 0 0.45">
          <joint name="right_knee" type="hinge" axis="0 1 0" range="0 2.5"/>
          <geom name="right_thigh_geom" type="capsule" fromto="0 0 0  0 0 0.45"
                size="0.05" mass="10" material="leg"/>
        </body>
      </body>

      <!-- PELVIS - connects both legs to torso -->
      <!-- Located at hip height: 0.05 (foot) + 0.45 (shin) + 0.45 (thigh) = 0.95m -->
      <body name="pelvis" pos="-0.05 0 0.95">
        <!-- Hip joints - control the thighs from here -->
        <joint name="left_hip" type="hinge" axis="0 1 0" range="-0.5 1.5"/>
        <joint name="right_hip" type="hinge" axis="0 1 0" range="-0.5 1.5"/>

        <!-- Pelvis geometry (small, mainly a connector) -->
        <geom name="pelvis_geom" type="box" size="0.08 0.18 0.08" mass="5"
              material="leg"/>

        <!-- TORSO with waist joint -->
        <body name="torso" pos="0 0 0.08">
          <joint name="waist" type="hinge" axis="0 1 0" range="-0.3 0.5"/>

          <!-- Torso: 0.50m, 30kg (reduced since pelvis now has 5kg) -->
          <geom name="torso_geom" type="capsule" fromto="0 0 0  0 0 0.50"
                size="0.10" mass="30" material="torso_mat"/>

          <!-- SHOULDERS AND HEAD -->
          <body name="shoulders" pos="0 0 0.45">
            <!-- Head -->
            <body name="head" pos="0 0 0.17">
              <geom name="head_geom" type="sphere" size="0.10"
                    mass="5" material="skin"/>
            </body>

            <!-- LEFT ARM -->
            <body name="left_upper_arm" pos="0 0.20 0">
              <joint name="left_shoulder" type="hinge" axis="0 1 0" range="-1.0 2.5"/>
              <!-- Upper arm: 0.30m, 3kg - hangs down -->
              <geom name="left_upper_arm_geom" type="capsule"
                    fromto="0 0 0  0 0 -0.30" size="0.03" mass="3" material="arm"/>

              <body name="left_forearm" pos="0 0 -0.30">
                <joint name="left_elbow" type="hinge" axis="0 1 0" range="0 2.5"/>
                <!-- Forearm: 0.25m, 2kg -->
                <geom name="left_forearm_geom" type="capsule"
                      fromto="0 0 0  0 0 -0.25" size="0.025" mass="2" material="arm"/>
                <site name="left_hand" pos="0 0 -0.25" size="0.03"/>
              </body>
            </body>

            <!-- RIGHT ARM -->
            <body name="right_upper_arm" pos="0 -0.20 0">
              <joint name="right_shoulder" type="hinge" axis="0 1 0" range="-1.0 2.5"/>
              <geom name="right_upper_arm_geom" type="capsule"
                    fromto="0 0 0  0 0 -0.30" size="0.03" mass="3" material="arm"/>

              <body name="right_forearm" pos="0 0 -0.30">
                <joint name="right_elbow" type="hinge" axis="0 1 0" range="0 2.5"/>
                <geom name="right_forearm_geom" type="capsule"
                      fromto="0 0 0  0 0 -0.25" size="0.025" mass="2" material="arm"/>
                <site name="right_hand" pos="0 0 -0.25" size="0.03"/>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Actuators -->
  <actuator>
    <!-- Leg actuators - main pumping motion -->
    <motor name="left_knee_motor" joint="left_knee" gear="150"/>
    <motor name="right_knee_motor" joint="right_knee" gear="150"/>
    <motor name="left_hip_motor" joint="left_hip" gear="200"/>
    <motor name="right_hip_motor" joint="right_hip" gear="200"/>

    <!-- Waist actuator -->
    <motor name="waist_motor" joint="waist" gear="250"/>

    <!-- Arm actuators -->
    <motor name="left_shoulder_motor" joint="left_shoulder" gear="50"/>
    <motor name="right_shoulder_motor" joint="right_shoulder" gear="50"/>
    <motor name="left_elbow_motor" joint="left_elbow" gear="30"/>
    <motor name="right_elbow_motor" joint="right_elbow" gear="30"/>
  </actuator>

  <!-- Sensors -->
  <sensor>
    <!-- Board state -->
    <framepos name="board_pos" objtype="body" objname="board"/>
    <framequat name="board_quat" objtype="body" objname="board"/>
    <framelinvel name="board_vel" objtype="body" objname="board"/>
    <frameangvel name="board_angvel" objtype="body" objname="board"/>

    <!-- Joint positions -->
    <jointpos name="left_knee_pos" joint="left_knee"/>
    <jointpos name="right_knee_pos" joint="right_knee"/>
    <jointpos name="left_hip_pos" joint="left_hip"/>
    <jointpos name="right_hip_pos" joint="right_hip"/>
    <jointpos name="waist_pos" joint="waist"/>
    <jointpos name="left_shoulder_pos" joint="left_shoulder"/>
    <jointpos name="right_shoulder_pos" joint="right_shoulder"/>

    <!-- Center of mass of rider (pelvis subtree) -->
    <subtreecom name="rider_com" body="pelvis"/>
  </sensor>
</mujoco>
